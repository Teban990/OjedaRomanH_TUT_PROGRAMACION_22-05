Algoritmo notas
	Definir nota Como Caracter
	
	Escribir "Ingrese una calificacion (A, B, C, D o F):"
	Leer nota
	
	Segun nota Hacer
		
		"A", "a":
			Escribir "Excelente"
			
		"B", "b":
			Escribir "Muy bueno"
			
		"C", "c":
			Escribir "Bueno"
			
		"D", "d":
			Escribir "Insuficiente"
			
		"F", "f":
			Escribir "Reprobado"
			
		De Otro Modo:
			Escribir "Calificacion invalida"
			
	FinSegun
	
FinAlgoritmo
